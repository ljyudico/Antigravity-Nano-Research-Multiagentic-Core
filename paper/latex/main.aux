\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Six-unit curriculum structure with notebook counts and key technologies per unit. Units 1-4 provide domain-specific knowledge (nanotechnology in this implementation, but transferable to other computational sciences), while Units 5-6 offer domain-agnostic multi-agent orchestration and deployment patterns applicable to any research domain.}}{3}{figure.1}\protected@file@percent }
\newlabel{fig:curriculum}{{1}{3}{Six-unit curriculum structure with notebook counts and key technologies per unit. Units 1-4 provide domain-specific knowledge (nanotechnology in this implementation, but transferable to other computational sciences), while Units 5-6 offer domain-agnostic multi-agent orchestration and deployment patterns applicable to any research domain}{figure.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Cost analysis for representative research usage scenarios. Real-world validation demonstrates genuine affordability: complete curriculum execution costs <\$2 using OpenRouter multi-provider access.}}{3}{table.2}\protected@file@percent }
\newlabel{tab:costs}{{2}{3}{Cost analysis for representative research usage scenarios. Real-world validation demonstrates genuine affordability: complete curriculum execution costs <\$2 using OpenRouter multi-provider access}{table.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Cost comparison across usage scenarios. The framework provides three cost tiers: (1) \textbf  {Zero-cost} — Demo Au$_{13}$ pipeline and Ollama local inference require no API access, (2) \textbf  {Ultra-low-cost} — Complete 25-notebook curriculum execution via OpenRouter costs <\$2, enabling genuine accessibility, and (3) \textbf  {Production} — Monthly active researcher costs <\$10, still 5× cheaper than GPT-4 baseline. The dual-path architecture addresses reproducibility without excluding resource-constrained institutions.}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:cost_comparison}{{2}{4}{Cost comparison across usage scenarios. The framework provides three cost tiers: (1) \textbf {Zero-cost} — Demo Au$_{13}$ pipeline and Ollama local inference require no API access, (2) \textbf {Ultra-low-cost} — Complete 25-notebook curriculum execution via OpenRouter costs <\$2, enabling genuine accessibility, and (3) \textbf {Production} — Monthly active researcher costs <\$10, still 5× cheaper than GPT-4 baseline. The dual-path architecture addresses reproducibility without excluding resource-constrained institutions}{figure.2}{}}
